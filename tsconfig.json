{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": ".vercel/output",
    "baseUrl": "."
  },
  "include": ["src/**/*", "api/**/*"],
  "exclude": ["node_modules"]
}
