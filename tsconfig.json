{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["src/**/*", "api/**/*"],
  "exclude": ["node_modules"]
}
