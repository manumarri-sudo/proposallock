{
  "name": "proposallock",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "node node_modules/esbuild/bin/esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.mjs --external:better-sqlite3"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "@hono/node-server": "^1.12.0",
    "better-sqlite3": "^11.0.0",
    "esbuild": "^0.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0"
  }
}
